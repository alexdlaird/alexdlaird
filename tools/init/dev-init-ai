#!/usr/bin/env bash

DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]:-$0}" )" &> /dev/null && pwd )

. "$DIR/../lib/init-helpers.sh"

section_header "Initializing AI"

if [[ "$(uname -s)" != "Linux" ]]; then
  echo "!!> AI environment setup is only supported on Linux"
  return 0 2>/dev/null || exit 1
fi

# Disable sleep/suspend (AI workstation should never sleep)
sudo systemctl mask sleep.target suspend.target hibernate.target hybrid-sleep.target
gsettings set org.gnome.settings-daemon.plugins.power sleep-inactive-ac-type 'nothing' 2>/dev/null || true

# Configure firewall: LAN-only for SSH and direct service access, docker0-only
# for inter-container traffic, block outgoing to LAN. Public off-LAN access
# happens via outbound ngrok tunnels (ssh/webui/ollama-ngrok-tunnel.service),
# never via direct inbound — the upstream Arcadyan gateway blocks that anyway.
sudo ufw allow from 192.168.86.0/22 to any port 22
sudo ufw allow from 192.168.86.0/22 to any port 3000
sudo ufw allow from 192.168.86.0/22 to any port 7860
sudo ufw allow from 192.168.86.0/22 to any port 11434
sudo ufw allow in on docker0 to any port 9099
sudo ufw allow in on docker0 to any port 11434
sudo ufw allow in on docker0 to any port 7860
sudo ufw default deny incoming
sudo ufw default allow outgoing
sudo ufw deny out to 192.168.86.0/22
if ! sudo ufw status | grep -q "Status: active"; then
  sudo ufw enable
fi

# Set apt flags based on interactive mode
APT_FLAGS=""
if [[ "$INTERACTIVE" != "true" ]]; then
  APT_FLAGS="-y"
fi

# Install/repair NVIDIA driver (reboot required before continuing). Uses
# `nvidia-smi -L` rather than `command -v` so a half-broken state — binary
# present, kernel module missing after a kernel upgrade — is detected as a
# repair case, not a no-op.
if ! nvidia-smi -L >/dev/null 2>&1; then
  sudo apt-get install $APT_FLAGS ubuntu-drivers-common
  sudo ubuntu-drivers install
  if ! nvidia-smi -L >/dev/null 2>&1; then
    echo ""
    echo "!!> NVIDIA driver installation failed (or kernel modules not built for current kernel)."
    echo "!!> Check 'sudo ubuntu-drivers list' and install manually, or try:"
    echo "!!>   sudo apt install --reinstall linux-modules-nvidia-\$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | cut -d. -f1)-open-\$(uname -r)"
    return 0 2>/dev/null || exit 1
  fi
  echo ""
  echo "!!> NVIDIA driver installed. A reboot is required before CUDA and Ollama can be set up."
  echo "!!> Please reboot, then rerun this script to complete AI setup."
  return 0 2>/dev/null || exit 0
fi

# Install CUDA toolkit
if ! command -v nvcc 2>&1 >/dev/null; then
  sudo apt-get install $APT_FLAGS nvidia-cuda-toolkit
fi

# Install system build dependencies (cmake for llama.cpp, libcurl for HuggingFace downloads)
sudo apt-get install $APT_FLAGS cmake libcurl4-openssl-dev

# Install Ollama
if ! command -v ollama 2>&1 >/dev/null; then
  curl -fsSL https://ollama.com/install.sh | sh
fi

# Configure the Ollama daemon. OLLAMA_HOST opens it to Docker containers.
# OLLAMA_KV_CACHE_TYPE=q4_0 quantizes KV cache so 256K context fits a 32GB
# card alongside the Qwen 27B weights (fp16 KV at 256K doesn't fit). Flash
# attention is required for KV-cache quantization to take effect.
if [[ ! -f /etc/systemd/system/ollama.service.d/override.conf ]]; then
  sudo mkdir -p /etc/systemd/system/ollama.service.d
  sudo tee /etc/systemd/system/ollama.service.d/override.conf > /dev/null <<'EOF'
[Service]
Environment="OLLAMA_HOST=0.0.0.0"
Environment="OLLAMA_FLASH_ATTENTION=1"
Environment="OLLAMA_KV_CACHE_TYPE=q4_0"
EOF
  sudo systemctl daemon-reload
  sudo systemctl restart ollama
fi

# Pull base models and alias them to stable names. The aliases (qwen / gemma)
# are what config.py, Makefile, pipeline.py, and setup-base-agent reference;
# bump the source tags below when new versions ship.
#
#   qwen  → coding agent path (fine-tuned into cortex / cortex-agent)
#   gemma → general QA path (RAG-wrapped chat in Open WebUI)
# Pinned to explicit flagship tags so a fresh bootstrap can't silently regress
# to a smaller :latest variant (Gemma 4's :latest resolves to the 8B 'e4b'
# multimodal lite, not the 31B dense flagship).
QWEN_SOURCE_TAG="${QWEN_SOURCE_TAG:-qwen3.6:27b}"
GEMMA_SOURCE_TAG="${GEMMA_SOURCE_TAG:-gemma4:31b}"

_ollama_has() {
  local pat="${1//\./\\.}"
  ollama list | awk 'NR>1 {print $1}' | grep -qE "^${pat}(:|$)"
}

_ensure_ollama_alias() {
  local alias="$1" source="$2"
  if _ollama_has "$alias"; then
    return 0
  fi
  if ! _ollama_has "$source"; then
    echo "--> pulling ${source} ..."
    ollama pull "${source}"
  fi
  echo "--> aliasing ${source} -> ${alias} ..."
  ollama cp "${source}" "${alias}"
  ollama rm "${source}" 2>/dev/null || true
}

_ensure_ollama_alias qwen "$QWEN_SOURCE_TAG"
_ensure_ollama_alias gemma "$GEMMA_SOURCE_TAG"
ollama pull nomic-embed-text

# Remove deprecated gemma4-agent overlay if present — replaced by qwen-agent
# (created by setup-base-agent below) for the agent path.
ollama rm gemma4-agent 2>/dev/null || true

# Create the qwen-agent overlay + cortex-agent alias. See the script for details;
# it's also callable standalone via `make setup-base-agent` for one-off bootstraps.
"$HOME/Developer/cortex/bin/setup-base-agent"

# Create shared Docker network for inter-container communication
docker network create cortex 2>/dev/null || true

# Start Qdrant
if ! docker ps -a --format '{{.Names}}' | grep -q '^qdrant$'; then
  docker run -d \
    --name qdrant \
    --restart unless-stopped \
    --network cortex \
    -p 6333:6333 \
    -p 6334:6334 \
    -v "$HOME/qdrant_storage:/qdrant/storage:z" \
    qdrant/qdrant
else
  docker network connect cortex qdrant 2>/dev/null || true
fi

# Start pipelines server (RAG middleware between Open WebUI and Ollama)
PIPELINE_DIR="$HOME/Developer/cortex/pipeline"
if ! docker ps -a --format '{{.Names}}' | grep -q '^pipelines$'; then
  docker run -d \
    --name pipelines \
    --restart no \
    --network cortex \
    --add-host=host.docker.internal:host-gateway \
    -p 9099:9099 \
    --env "PIPELINES_REQUIREMENTS_PATH=/app/pipelines/requirements.txt" \
    -v pipelines:/app/pipelines \
    ghcr.io/open-webui/pipelines:main
  echo "--> Waiting for pipelines container to initialize ..."
  until docker logs pipelines 2>&1 | grep -q "Application startup complete\|Uvicorn running"; do sleep 3; done
  docker cp "$PIPELINE_DIR/pipeline.py" pipelines:/app/pipelines/pipeline.py
  docker cp "$PIPELINE_DIR/requirements.txt" pipelines:/app/pipelines/requirements.txt
  docker cp "$HOME/Developer/cortex/prompts" pipelines:/app/pipelines/prompts
  docker update --restart unless-stopped pipelines
  docker restart pipelines
  echo "--> Waiting for pipelines to restart with pipeline loaded ..."
  until docker logs pipelines 2>&1 | grep -q "Loaded module: pipeline"; do sleep 3; done
else
  docker network connect cortex pipelines 2>/dev/null || true
  echo "--> pipelines already exists, skipping (recreate manually if pipeline files changed)"
fi

# Install Forge (lllyasviel/stable-diffusion-webui-forge — actively maintained
# A1111 fork with first-class FLUX support). Open WebUI's automatic1111 engine
# talks to Forge unchanged: the /sdapi/v1/* surface is identical.
INSTALL_IMAGE_GEN=false
if [[ "$INTERACTIVE" == "true" ]]; then
  echo -n "Install image generation support (Forge + FLUX.1 [dev] fp8, ~17GB)? [y/N] "
  read -r _img_reply
  [[ "$_img_reply" =~ ^[Yy] ]] && INSTALL_IMAGE_GEN=true
fi
if [[ "$INSTALL_IMAGE_GEN" == "true" ]]; then
  FORGE_DIR="$HOME/stable-diffusion-webui-forge"
  FORGE_MODEL_DIR="$FORGE_DIR/models/Stable-diffusion"
  FORGE_MODEL="flux1-dev-fp8.safetensors"
  # All-in-one fp8 checkpoint published by Forge's author. Non-gated (unlike
  # black-forest-labs/FLUX.1-dev which requires HF login + license accept) and
  # bakes in the VAE + text encoders so Forge loads it as a single file.
  FORGE_MODEL_URL="https://huggingface.co/lllyasviel/flux1_dev/resolve/main/flux1-dev-fp8.safetensors"
  if [[ ! -d "$FORGE_DIR" ]]; then
    sudo add-apt-repository ppa:deadsnakes/ppa -y
    sudo apt-get update
    # libcairo2-dev is for pycairo (svglib build dep, used by the legacy
    # controlnet preprocessor); not needed for FLUX, but cheap to install
    # and silences a noisy install-time warning.
    sudo apt-get install $APT_FLAGS git python3.10 python3.10-venv python3.10-dev libgl1 libglib2.0-0 libcairo2-dev
    git clone https://github.com/lllyasviel/stable-diffusion-webui-forge "$FORGE_DIR"
  fi
  if [[ ! -f "$FORGE_MODEL_DIR/$FORGE_MODEL" ]]; then
    mkdir -p "$FORGE_MODEL_DIR"
    echo "--> Downloading FLUX.1 [dev] fp8 (~17GB) ..."
    wget -q --show-progress -O "$FORGE_MODEL_DIR/$FORGE_MODEL" "$FORGE_MODEL_URL"
  fi
  # Pre-create the venv with a setuptools that still ships pkg_resources, and
  # preinstall openai/CLIP with build isolation off. Forge inherits A1111's
  # CLIP install (`pip install <github-zip>`) which builds from setup.py and
  # imports pkg_resources — modern setuptools (>=70) makes that optional, so
  # the default isolated build env doesn't have it and CLIP fails to install.
  if [[ ! -d "$FORGE_DIR/venv" ]]; then
    python3.10 -m venv "$FORGE_DIR/venv"
    "$FORGE_DIR/venv/bin/pip" install wheel "setuptools==69.5.1"
    CLIP_URL="https://github.com/openai/CLIP/archive/d50d76daa670286dd6cacf3bcd80b5e4823fc8e1.zip"
    "$FORGE_DIR/venv/bin/pip" install --no-build-isolation "$CLIP_URL"
    # joblib silences the soft_inpainting builtin extension's import-time error.
    "$FORGE_DIR/venv/bin/pip" install joblib
  fi
  if [[ ! -f /etc/systemd/system/forge.service ]]; then
    # TORCH_COMMAND overrides Forge's default torch install (2.3.1+cu121),
    # which predates Blackwell (RTX 5090, sm_120) support. cu128 wheels are
    # the lowest line that ships sm_120 kernels.
    sudo tee /etc/systemd/system/forge.service > /dev/null <<EOF
[Unit]
Description=Stable Diffusion WebUI Forge (FLUX)
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=$USER
WorkingDirectory=$FORGE_DIR
Environment="PYTHON_CMD=python3.10"
Environment="TORCH_COMMAND=pip install torch torchvision --index-url https://download.pytorch.org/whl/cu128"
Environment="COMMANDLINE_ARGS=--always-offload-from-vram --api --listen --skip-python-version-check --port 7860"
ExecStart=$FORGE_DIR/webui.sh
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF
    sudo systemctl daemon-reload
    sudo systemctl enable forge
    sudo systemctl start forge
    echo "--> forge service installed and started (first run will take several minutes for venv + torch install)"
  fi
fi

# Prompt for optional Open WebUI features
ENABLE_WEB_SEARCH_FLAG=false
ENABLE_IMAGE_GEN_FLAG=false
if [[ "$INTERACTIVE" == "true" ]]; then
  echo -n "Enable web search in Open WebUI (DuckDuckGo)? [y/N] "
  read -r _ws_reply
  [[ "$_ws_reply" =~ ^[Yy] ]] && ENABLE_WEB_SEARCH_FLAG=true
  if [[ "$INSTALL_IMAGE_GEN" == "true" ]]; then
    ENABLE_IMAGE_GEN_FLAG=true
  fi
fi

# Start Open WebUI (pointed at pipelines server instead of Ollama directly)
if ! docker ps -a --format '{{.Names}}' | grep -q '^open-webui$'; then
  OW_ARGS=(
    --name open-webui
    --restart unless-stopped
    --add-host=host.docker.internal:host-gateway
    -p 3000:8080
    --env "OPENAI_API_BASE_URL=http://host.docker.internal:9099/v1"
    --env 'OPENAI_API_KEY=0p3n-w3bu!'
    --env "ENABLE_EVALUATION_ARENA_MODELS=false"
    -v open-webui:/app/backend/data
  )
  if [[ "$ENABLE_WEB_SEARCH_FLAG" == "true" ]]; then
    OW_ARGS+=(--env "ENABLE_WEB_SEARCH=True" --env "WEB_SEARCH_ENGINE=duckduckgo")
  fi
  if [[ "$ENABLE_IMAGE_GEN_FLAG" == "true" ]]; then
    OW_ARGS+=(--env "ENABLE_IMAGE_GENERATION=True" --env "IMAGE_GENERATION_ENGINE=automatic1111" --env "AUTOMATIC1111_BASE_URL=http://host.docker.internal:7860")
  fi
  docker run -d "${OW_ARGS[@]}" ghcr.io/open-webui/open-webui:main
else
  echo "--> open-webui already exists, skipping (recreate manually if env vars need updating)"
fi

# Provision RAG, fine-tuning, and pipeline dirs into private-dev
CORTEX_DIR="$HOME/Developer/cortex"
PRIVATE_CORTEX="$HOME/Developer/private-dev/servers/cortex"
ln -sf "$CORTEX_DIR/rag/Makefile" "$PRIVATE_CORTEX/rag/Makefile"
ln -snf "$CORTEX_DIR/rag" "$PRIVATE_CORTEX/rag/engine"
ln -sf "$CORTEX_DIR/finetune/Makefile" "$PRIVATE_CORTEX/finetune/Makefile"
ln -snf "$CORTEX_DIR/finetune" "$PRIVATE_CORTEX/finetune/engine"
mkdir -p "$PRIVATE_CORTEX/pipeline"

# Install fine-tuning dependencies (Unsloth, HuggingFace)
if ! python -c "import unsloth" 2>/dev/null; then
  CUDA_VER=$(nvcc --version | grep -oP 'release \K[0-9]+\.[0-9]+' | tr -d '.')
  TORCH_VER=$(python -c "import torch; v=torch.__version__; print(v[:v.index('+')] if '+' in v else v)" 2>/dev/null | tr -d '.')
  echo "--> Installing Unsloth for CUDA ${CUDA_VER}, torch ${TORCH_VER}"
  pip install torch --index-url "https://download.pytorch.org/whl/cu${CUDA_VER}"
  pip install "unsloth" trl datasets huggingface_hub
fi

# Install pi and opencode coding agents (point at local Ollama; share the cortex-agent config)
. "$DIR/dev-init-nvm"

if ! command -v pi >/dev/null 2>&1; then
  curl -fsSL https://pi.dev/install.sh | bash
fi

if ! command -v opencode >/dev/null 2>&1; then
  curl -fsSL https://opencode.ai/install | bash
fi

. "$DIR/init-pi-opencode.sh"

# HuggingFace login is optional for the current setup — Qwen3.6-27B (the
# fine-tune base) is Apache 2.0 and downloads anonymously. Login only matters
# if you swap in a gated model later (e.g., a Gemma variant). Left in as a
# convenience prompt for that case.
if ! hf auth whoami 2>/dev/null; then
  echo ""
  echo "!!> Optional: HuggingFace login. Required only for gated models."
  echo "    Create a token at: https://huggingface.co/settings/tokens"
  if [[ "$INTERACTIVE" == "true" ]]; then
    hf auth login || true
  else
    echo "!!> Skipping HuggingFace login in unattended mode — run 'hf auth login' manually if needed."
  fi
fi

section_footer "AI setup"
