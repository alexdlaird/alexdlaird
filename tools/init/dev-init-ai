#!/usr/bin/env bash

DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

. "$DIR/../lib/init-helpers.sh"

section_header "Initializing AI"

if [[ "$(uname -s)" != "Linux" ]]; then
  echo "!!> AI environment setup is only supported on Linux"
  return 0 2>/dev/null || exit 1
fi

PRIMARY_NETWORK="192.168.86"

# Verify VLAN isolation before continuing
current_ip=$(hostname -I | awk '{print $1}')
while [[ "$current_ip" == ${PRIMARY_NETWORK}.* ]]; do
  echo ""
  echo "!!> cortex appears to be on the primary network (${current_ip})."
  echo "    Configure an isolated VLAN, and only install AI models in"
  echo "    that isolated environment. Set this up at the router/switch,"
  echo "    then renew the IP:"
  echo "      sudo dhclient -r && sudo dhclient"
  if [[ "$INTERACTIVE" != "true" ]]; then
    echo "!!> Cannot continue in unattended mode without VLAN isolation."
    return 0 2>/dev/null || exit 1
  fi
  read -p "    Press Enter to recheck... "
  current_ip=$(hostname -I | awk '{print $1}')
done

# Set apt flags based on interactive mode
APT_FLAGS=""
if [[ "$INTERACTIVE" != "true" ]]; then
  APT_FLAGS="-y"
fi

# Install NVIDIA driver (reboot required before continuing)
if ! command -v nvidia-smi 2>&1 >/dev/null; then
  sudo apt-get install $APT_FLAGS nvidia-driver-560 nvidia-utils-560
  echo ""
  echo "!!> NVIDIA driver installed. A reboot is required before CUDA and Ollama can be set up."
  echo "!!> Please reboot, then rerun this script to complete AI setup."
  return 0 2>/dev/null || exit 0
fi

# Install CUDA toolkit
if ! command -v nvcc 2>&1 >/dev/null; then
  sudo apt-get install $APT_FLAGS nvidia-cuda-toolkit
fi

# Install Ollama
if ! command -v ollama 2>&1 >/dev/null; then
  curl -fsSL https://ollama.com/install.sh | sh
fi

# Configure Ollama to listen on all interfaces (required for Docker containers)
if [[ ! -f /etc/systemd/system/ollama.service.d/override.conf ]]; then
  sudo mkdir -p /etc/systemd/system/ollama.service.d
  printf '[Service]\nEnvironment="OLLAMA_HOST=0.0.0.0"\n' \
    | sudo tee /etc/systemd/system/ollama.service.d/override.conf > /dev/null
  sudo systemctl daemon-reload
  sudo systemctl restart ollama
fi

# Pull models
ollama pull gemma4
ollama pull nomic-embed-text

# Start Qdrant
if ! docker ps -a --format '{{.Names}}' | grep -q '^qdrant$'; then
  docker run -d \
    --name qdrant \
    --restart unless-stopped \
    -p 6333:6333 \
    -p 6334:6334 \
    -v "$HOME/qdrant_storage:/qdrant/storage:z" \
    qdrant/qdrant
fi

# Start Open WebUI
if ! docker ps -a --format '{{.Names}}' | grep -q '^open-webui$'; then
  docker run -d \
    --name open-webui \
    --restart unless-stopped \
    --add-host=host.docker.internal:host-gateway \
    -p 3000:8080 \
    -v open-webui:/app/backend/data \
    ghcr.io/open-webui/open-webui:main
fi

# Provision RAG and fine-tuning Makefiles into private-dev
PRIVATE_CORTEX="$HOME/Developer/private-dev/servers/cortex"
ln -sf "$DIR/../cortex/rag/Makefile" "$PRIVATE_CORTEX/rag/Makefile"
ln -sf "$DIR/../cortex/finetune/Makefile" "$PRIVATE_CORTEX/finetune/Makefile"

# Install fine-tuning dependencies (Unsloth, HuggingFace)
if ! python -c "import unsloth" 2>/dev/null; then
  CUDA_VER=$(nvcc --version | grep -oP 'release \K[0-9]+\.[0-9]+' | tr -d '.')
  TORCH_VER=$(python -c "import torch; v=torch.__version__; print(v[:v.index('+')] if '+' in v else v)" 2>/dev/null | tr -d '.')
  echo "--> Installing Unsloth for CUDA ${CUDA_VER}, torch ${TORCH_VER}"
  pip install torch --index-url "https://download.pytorch.org/whl/cu${CUDA_VER}"
  pip install "unsloth" trl datasets huggingface_hub
fi

# Prompt for HuggingFace login if not already authenticated
if ! huggingface-cli whoami 2>/dev/null; then
  echo ""
  echo "!!> HuggingFace login required to download gated models (e.g. Gemma 4)."
  echo "    Accept the model license at: https://huggingface.co/google/gemma-4-27b-it"
  echo "    Then create a token at: https://huggingface.co/settings/tokens"
  if [[ "$INTERACTIVE" == "true" ]]; then
    huggingface-cli login
  else
    echo "!!> Skipping HuggingFace login in unattended mode — run 'huggingface-cli login' manually."
  fi
fi

section_footer "AI setup"
