#!/usr/bin/env zsh

OS_NAME=$(uname -s)
DIR="$( dirname "$0" )"
. "$DIR/../lib/init-helpers.sh"
. "$HOME/.zshrc"

if [[ "$(uname -m)" == "x86_64" ]]; then
  OS_ARCH="amd64"
else
  OS_ARCH="arm64"
fi

section_header "Initializing jenv"

block-manager "$DIR/../lib/rc-jenv.sh" "$HOME/.zshrc" "jenv"
. "$DIR/../lib/rc-jenv.sh"

echo "--> JDK 1.8 must be installed and configured manually, if it is needed"

# Helper to add JDK to jenv only if not already added
jenv_add_if_missing() {
  local jdk_path="$1"
  if [[ -d "$jdk_path" ]] && ! jenv versions 2>/dev/null | grep -q "$(basename "$jdk_path")"; then
    jenv add "$jdk_path" 2>/dev/null || true
  fi
}

if [[ "$OS_NAME" == "Darwin" ]]; then
  jenv_add_if_missing /opt/homebrew/opt/openjdk@11
  echo "--> For IntelliJ, add JDK path /opt/homebrew/opt/openjdk@11/libexec/openjdk.jdk/Contents/Home"
  jenv_add_if_missing /opt/homebrew/opt/openjdk@17
  echo "--> For IntelliJ, add JDK path /opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home"
  jenv_add_if_missing /opt/homebrew/opt/openjdk@21
  echo "--> For IntelliJ, add JDK path /opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home"
  jenv_add_if_missing /opt/homebrew/opt/openjdk
  echo "--> For IntelliJ, add JDK path /opt/homebrew/opt/openjdk/libexec/openjdk.jdk/Contents/Home"
else
  jenv_add_if_missing /usr/lib/jvm/java-17-openjdk-$OS_ARCH

  if ! command -v raspi-config 2>&1 >/dev/null; then
    jenv_add_if_missing /usr/lib/jvm/java-8-openjdk-$OS_ARCH
    jenv_add_if_missing /usr/lib/jvm/java-11-openjdk-$OS_ARCH
    jenv_add_if_missing /usr/lib/jvm/java-21-openjdk-$OS_ARCH
  fi
fi

section_footer "jenv setup"
