#!/usr/bin/env bash

. "$DIR/../lib/init-helpers.sh"

section_header "Initializing brew"

if ! command -v brew 2>&1 >/dev/null; then
  if [[ "$INTERACTIVE" != "true" ]]; then
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  else
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
fi

. "$DIR/../lib/rc-brew.sh"

brew tap hashicorp/tap
brew tap twilio/brew

brew install zsh vim tmux \
             pyenv python@3.12 \
             jenv maven sbt openjdk openjdk@11 openjdk@17 openjdk@21 scala@2.13 \
             autoenv \
             nvm \
             dart-sdk \
             lcov fastlane imagemagick \
             docker docker-completion sqlite \
             ffmpeg bento4 gettext grep gnu-sed wget curl \
             openssl@3 ca-certificates gpg \
             awscli awslogs gh twilio hashicorp/tap/terraform
             anomalyco/tap/opencode

brew install --cask android-commandlinetools claude-code

npm install -g @mariozechner/pi-coding-agent

curl -fsSL https://ollama.com/install.sh | sh

# Symlink autoenv (skip if already exists)
if [[ ! -L "$HOME/.autoenv" ]]; then
  ln -s "$(brew --prefix autoenv)" "$HOME/.autoenv"
fi

# Configure pi to use cortex RAG pipeline
mkdir -p "$HOME/.pi/agent"
cat > "$HOME/.pi/agent/models.json" << 'EOF'
{
  "providers": {
    "cortex": {
      "baseUrl": "http://cortex:9099/v1",
      "api": "openai-completions",
      "apiKey": "0p3n-w3bu!",
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false
      },
      "models": [
        {
          "id": "cortex",
          "name": "cortex",
          "reasoning": true,
          "input": ["text"],
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        }
      ]
    }
  }
}
EOF
# Set cortex as pi's default model (merge into existing settings if present)
PI_SETTINGS="$HOME/.pi/agent/settings.json"
if [[ -f "$PI_SETTINGS" ]]; then
  tmp=$(mktemp)
  python3 -c "
import json, sys
s = json.load(open('$PI_SETTINGS'))
s['defaultProvider'] = 'cortex'
s['defaultModel'] = 'cortex'
json.dump(s, open('$tmp', 'w'), indent=2)
"
  mv "$tmp" "$PI_SETTINGS"
else
  echo '{"defaultProvider":"cortex","defaultModel":"cortex"}' > "$PI_SETTINGS"
fi

section_footer "brew setup"
