#!/usr/bin/env zsh

DIR="$( dirname "$0" )"
. "$HOME/.zshrc"

echo "---------------------------------------------"
echo " Initializing node ..."
echo "---------------------------------------------"

block-manager "$DIR/../lib/rc-nvm.sh" "$HOME/.zshrc" "nvm"
. "$HOME/.zshrc"

# Install Node versions (skip if already installed)
nvm ls 18 2>/dev/null | grep -q "v18" || nvm install 18
nvm ls 22 2>/dev/null | grep -q "v22" || nvm install 22

echo "---------------------------------------------"
echo " ... finished node setup"
echo "---------------------------------------------"
