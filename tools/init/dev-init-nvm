#!/usr/bin/env zsh

DIR="$( dirname "$0" )"
. "$DIR/../lib/init-helpers.sh"
. "$HOME/.zshrc"

section_header "Initializing nvm/Node"

block-manager "$DIR/../lib/rc-nvm.sh" "$HOME/.zshrc" "nvm"
. "$DIR/../lib/rc-nvm.sh"

# Install Node versions (skip if already installed)
nvm ls 20 2>/dev/null | grep -q "v20" || nvm install 20
nvm ls 22 2>/dev/null | grep -q "v22" || nvm install 22

section_footer "nvm/Node setup"
