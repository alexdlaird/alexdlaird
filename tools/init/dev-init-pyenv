#!/usr/bin/env zsh

DIR="$( dirname "$0" )"
. "$DIR/../lib/init-helpers.sh"
. "$HOME/.zshrc"

section_header "Initializing pyenv"

block-manager "$DIR/../lib/rc-pyenv.sh" "$HOME/.zshrc" "pyenv"
. "$HOME/.zshrc"

# Install Python versions (skip if already installed)
pyenv versions --bare | grep -q "^3\.12" || pyenv install 3.12
pyenv global 3.12

python -m pip install --quiet pyngrok amazon-orders hookee heliumcli \
                      GitPython Flask pytest coverage mypy Sphinx \
                      plexapi

if ! command -v raspi-config 2>&1 >/dev/null; then
  pyenv versions --bare | grep -q "^2\.7" || pyenv install 2.7
  pyenv versions --bare | grep -q "^3\.6" || pyenv install 3.6
  pyenv versions --bare | grep -q "^3\.9" || pyenv install 3.9
  pyenv versions --bare | grep -q "^pypy3\.10" || pyenv install pypy3.10
fi

section_footer "pyenv setup"
