#!/usr/bin/env bash

OS_NAME=$(uname -s)
DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Export INTERACTIVE so child scripts can use it
export INTERACTIVE=${INTERACTIVE:-true}

. "$DIR/../lib/init-helpers.sh"

echo "============================================="
echo " Initializing $OS_NAME ..."
if [[ "$INTERACTIVE" != "true" ]]; then
  echo " (unattended mode)"
fi
echo "============================================="

# 1. System packages (brew/apt) - all or nothing, prompt once
if confirm "Install system packages (brew/apt)?"; then
  if [[ "$OS_NAME" == "Darwin" ]]; then
    . "$DIR/dev-init-mac-brew"
  elif [[ "$OS_NAME" == "Linux" ]]; then
    if [ -f "/etc/debian_version" ]; then
      if command -v raspi-config 2>&1 >/dev/null; then
        . "$DIR/dev-init-pi"
      else
        . "$DIR/dev-init-debian"
      fi
    else
      echo "!!> Operating system not supported for automatic provisioning"
      exit 1
    fi
  else
    echo "!!> Operating system not supported for automatic provisioning"
    exit 1
  fi
fi

# 2. Shell framework (prezto) - always runs, no prompt
chsh -s /bin/zsh
zsh "$DIR/dev-init-prezto"

# 3. Dev tools/dotfiles - all or nothing, prompt once
if confirm "Configure dev tools and dotfiles?"; then
  zsh "$DIR/dev-init-tools"
fi

# 4. Python (pyenv) - all or nothing, prompt once
if confirm "Install Python environment (pyenv)?"; then
  zsh "$DIR/dev-init-pyenv"
fi

# 5. Java (jenv) - all or nothing, prompt once
if confirm "Install Java environment (jenv)?"; then
  zsh "$DIR/dev-init-jenv"
fi

# 6. SDKMAN (scala) - all or nothing, prompt once (non-Pi only)
if ! command -v raspi-config 2>&1 >/dev/null; then
  if confirm "Install SDKMAN (Scala)?"; then
    zsh "$DIR/dev-init-sdkman"
  fi
fi

# 7. Node (nvm) - all or nothing, prompt once
if confirm "Install Node environment (nvm)?"; then
  zsh "$DIR/dev-init-nvm"
fi

# 8. Flutter (fvm) - all or nothing, prompt once (non-Pi only)
if ! command -v raspi-config 2>&1 >/dev/null; then
  if confirm "Install Flutter environment (fvm)?"; then
    zsh "$DIR/dev-init-flutter"
  fi
fi

# 9. AI environment (Ollama) - Linux only
if [[ "$OS_NAME" == "Linux" ]]; then
  if confirm "Install AI environment (Ollama)?"; then
    . "$DIR/dev-init-ai"
  fi
fi

echo "============================================="
echo " ... finished system setup"
echo "============================================="
